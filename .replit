modules = ["nodejs-20", "web", "python-3.12"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
AI_CREDENTIALS_ENCRYPTION_KEY = "64cf9fb27c8e994ac689944f2792827d4dfec601c4bf81c88998ea269c7ff684"
