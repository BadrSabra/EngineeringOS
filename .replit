modules = ["nodejs-20", "web", "python-3.12"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
AI_CREDENTIALS_ENCRYPTION_KEY = "48fc84bc494b9d76da4eb904c4854f96422cb2b1595c134d9a8c6f56b15d0909"
